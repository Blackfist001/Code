<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>

        <!-- Désactiver le listage des dossiers (équivalent Options -Indexes) -->
        <directoryBrowse enabled="false" />

        <!-- Déclarer index.php comme document par défaut (évite le 403) -->
        <defaultDocument>
            <enabled>true</enabled>
            <files>
                <clear />
                <add value="index.php" />
            </files>
        </defaultDocument>

        <!-- Réécriture d'URL : tout redirige vers index.php sauf les fichiers/dossiers existants -->
        <rewrite>
            <rules>
                <!-- Forcer la racine du site vers index.php (évite 403.13 sur "/") -->
                <rule name="Root to index.php" stopProcessing="true">
                    <match url="^$" />
                    <action type="Rewrite" url="index.php" appendQueryString="true" />
                </rule>

                <rule name="Route everything to index.php" stopProcessing="true">
                    <match url="^(.*)$" />
                    <conditions logicalGrouping="MatchAll">
                        <!-- Ne pas réécrire si le fichier existe réellement (CSS, JS, images...) -->
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <!-- Ne pas réécrire si le dossier existe réellement -->
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="/index.php" appendQueryString="true" />
                </rule>
            </rules>
        </rewrite>

        <!-- Handler PHP FastCGI — adapter le chemin à l'installation réelle de PHP sur le serveur -->
        <handlers>
            <add name="PHP_FastCGI"
                 path="*.php"
                 verb="*"
                 modules="FastCgiModule"
                 scriptProcessor="C:\PHP\php-cgi.exe"
                 resourceType="Either"
                 requireAccess="Script" />
        </handlers>

        <!-- Pages d'erreur personnalisées (optionnel) -->
        <httpErrors errorMode="DetailedLocalOnly" />

    </system.webServer>
</configuration>
